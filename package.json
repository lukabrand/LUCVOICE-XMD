{
  "name": "lucvoice-xmd",
  "version": "2.0.0",
  "description": "LUCVOICE-XMD - Advanced WhatsApp bot with QR pairing, session management, auto-reconnect, and express server",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "bot": "pm2 start index.js --name \"LUCVOICE-XMD\" --attach --max-memory-restart 200M --no-daemon",
    "dev": "nodemon index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "logs": "pm2 logs LUCVOICE-XMD",
    "restart": "pm2 restart LUCVOICE-XMD",
    "stop": "pm2 stop LUCVOICE-XMD",
    "update-deps": "npm install whatsapp-web.js@latest axios@latest express@latest dotenv@latest qrcode-terminal@latest chalk@latest moment@latest fs-extra@latest node-fetch@latest"
  },
  "dependencies": {
    "axios": "^1.6.3",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.20.0",
    "moment": "^2.29.4",
    "fs-extra": "^11.1.1",
    "node-fetch": "^3.3.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.48.0",
    "prettier": "^3.9.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lukabrand/LUCVOICE-XMD.git"
  },
  "keywords": [
    "WhatsApp",
    "bot",
    "LUCVOICE-XMD",
    "QR code",
    "session",
    "auto-reconnect",
    "PM2",
    "Node.js",
    "Express",
    "commands"
  ],
  "author": "LUCVOICE-XMD",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lukabrand/LUCVOICE-XMD/issues"
  },
  "homepage": "https://github.com/lukabrand/LUCVOICE-XMD#readme"
}
