# ===============================
#        LUCVOICE-XMD BOT
# ===============================

# -------------------------------
# Owner / Bot Info
# -------------------------------
OWNER_NAME="LUCVOICE-XMD"
OWNER_NUMBER="YOUR_NUMBER_HERE"       # Include country code, e.g. +255768619068
BOT_NAME="LUCVOICE-XMD"
PREFIX="."                             # Command prefix
PUBLIC_MODE="yes"                      # yes=public, no=private

# -------------------------------
# WhatsApp Session
# -------------------------------
SESSION_TYPE="local"                   # local / sessionweb
AUTO_RECONNECT="true"                  # Automatic reconnection on disconnect

# -------------------------------
# Express Server
# -------------------------------
PORT=3000
PUBLIC_URL=""                          # Optional public URL for session page

# -------------------------------
# Menu & Media
# -------------------------------
IMAGE_MENU="https://telegra.ph/file/0c225f7da5616cdcbec.jpg"  # Default menu image
STICKER_PACK="LUCVOICE-XMD Bot"       # Default sticker pack
STICKER_AUTHOR="LUCVOICE-XMD"         # Default sticker author
WELCOME_MESSAGE="Welcome to LUCVOICE-XMD!" # Default welcome message

# -------------------------------
# Optional API Keys (for integrations)
# -------------------------------
OPENAI_API_KEY=""                      # Your OpenAI API key
WEATHER_API_KEY=""                     # Weather API key (optional)

# -------------------------------
# Logging & Debug
# -------------------------------
LOG_LEVEL="info"                       # debug, info, warn, error
ENABLE_LOGS="true"                     # Enable or disable logging

# -------------------------------
# Advanced Features
# -------------------------------
ANTI_DELETE="true"                     # If true, bot prevents message deletion
AUTO_BIO="true"                        # Bot automatically updates bio/status
AUTO_CHAT="false"                       # Enable AI auto chat (if implemented)
MAX_MEMORY="200M"                       # Memory limit for PM2 auto-restart
